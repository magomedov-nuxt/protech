{
  "name": "protech",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "start": "node .output/server/index.mjs",
    "typecheck": "nuxt typecheck",
    "lint": "nuxt prepare && eslint .",
    "prisma:validate": "prisma validate --schema ./server/prisma",
    "prisma:generate": "prisma generate --schema ./server/prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema ./server/prisma",
    "test:integration": "vitest run",
    "check": "npm run prisma:validate && npm run prisma:generate && npm run typecheck && npm run lint",
    "preview": "nuxt preview",
    "postinstall": "npm run prisma:generate && nuxt prepare"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.10.0",
    "@lucide/vue": "^1.24.0",
    "@nuxt/ui": "^4.9.0",
    "@nuxtjs/seo": "^5.3.2",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/vite": "^4.3.2",
    "@takumi-rs/core": "^2.0.0-rc.16",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vueuse/nuxt": "^14.3.0",
    "better-auth": "^1.6.21",
    "dotenv": "^17.4.2",
    "nodemailer": "^9.0.3",
    "nuxt": "^4.4.8",
    "pg": "^8.22.0",
    "pinia-plugin-persistedstate": "^4.7.1",
    "tailwindcss": "^4.3.2",
    "vue": "^3.5.35",
    "vue-sonner": "^2.0.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.117",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "^26.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.7.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
